{
  "$schema": "https://schema.tauri.app/config/2/capability",
  "identifier": "default",
  "description": "Default capabilities for Graf-Id desktop shell",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:tray:default",
    "core:menu:default",
    "core:window:allow-close",
    "core:window:allow-hide",
    "core:window:allow-show",
    "core:window:allow-set-focus",
    "dialog:default"
  ]
}

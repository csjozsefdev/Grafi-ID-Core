{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Graf-Id",
  "version": "0.1.0",
  "identifier": "com.grafid.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build && npm run build:runtime",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Graf-Id",
        "width": 1100,
        "height": 720,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "resources": {
      "runtime/": "runtime/"
    }
  }
}
